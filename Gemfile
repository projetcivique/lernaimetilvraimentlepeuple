source 'https://rubygems.org'

# Framework web
gem 'sinatra'
gem 'sinatra-contrib'   # reloader en dev, helpers utiles

# Serveur
gem 'puma'

# Base de données
gem 'sequel'
gem 'sqlite3'

# Requêtes HTTP (pour les importers)
gem 'httparty'

# Parsing HTML/XML
gem 'nokogiri'

# Variables d'environnement
gem 'dotenv'

group :development, :test do
  gem 'minitest'
  gem 'rack-test'       # tester les routes Sinatra
end
